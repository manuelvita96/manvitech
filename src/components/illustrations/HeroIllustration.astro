---
// Illustrazione vettoriale originale: un "pannello browser" stilizzato con
// elementi fluttuanti ed elementi organici, coerente con la palette del brand.
---

<svg viewBox="0 0 480 440" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-auto w-full" role="img" aria-label="Illustrazione di un sito internet moderno con elementi grafici fluttuanti">
  <defs>
    <linearGradient id="hero-grad-1" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#ED7D31" />
      <stop offset="1" stop-color="#F0396A" />
    </linearGradient>
    <linearGradient id="hero-grad-2" x1="0" y1="1" x2="1" y2="0">
      <stop offset="0" stop-color="#FFC79A" />
      <stop offset="1" stop-color="#ED7D31" />
    </linearGradient>
    <filter id="hero-shadow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="0" dy="14" stdDeviation="16" flood-color="#171717" flood-opacity="0.14" />
    </filter>
  </defs>

  <!-- Blob organico di sfondo -->
  <path class="hero-float-slow" d="M60 120C90 60 190 30 260 55C330 80 400 70 420 140C440 210 400 280 330 300C260 320 210 380 140 360C70 340 30 270 35 200C38 165 40 150 60 120Z" fill="url(#hero-grad-2)" opacity="0.18" />

  <!-- Pannello browser principale -->
  <g filter="url(#hero-shadow)">
    <rect x="70" y="70" width="340" height="230" rx="20" fill="white" />
    <rect x="70" y="70" width="340" height="34" rx="20" fill="#F7F7F7" />
    <circle cx="90" cy="87" r="5" fill="#ED7D31" />
    <circle cx="108" cy="87" r="5" fill="#D8D8D8" />
    <circle cx="126" cy="87" r="5" fill="#D8D8D8" />

    <rect x="92" y="126" width="150" height="14" rx="7" fill="#262626" />
    <rect x="92" y="150" width="220" height="8" rx="4" fill="#B8B8B8" />
    <rect x="92" y="166" width="180" height="8" rx="4" fill="#B8B8B8" />

    <rect x="92" y="196" width="100" height="34" rx="17" fill="url(#hero-grad-1)" />

    <rect x="230" y="196" width="150" height="74" rx="14" fill="#FFF4EC" />
    <path d="M255 245c8-22 20-30 30-14 8-16 24-10 26 6 2 12-10 20-28 24-16-4-30-8-28-16Z" fill="url(#hero-grad-1)" opacity="0.85" />
  </g>

  <!-- Elementi fluttuanti -->
  <g class="hero-float">
    <circle cx="410" cy="110" r="26" fill="url(#hero-grad-1)" />
    <path d="M400 110l7 7 13-13" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" fill="none" />
  </g>

  <g class="hero-float-delayed">
    <rect x="30" y="250" width="70" height="70" rx="20" fill="white" filter="url(#hero-shadow)" />
    <path d="M52 285l12 12 22-24" stroke="#ED7D31" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" fill="none" />
  </g>

  <g class="hero-float-slow">
    <circle cx="140" cy="40" r="10" fill="#F0396A" opacity="0.7" />
    <circle cx="440" cy="330" r="14" fill="#ED7D31" opacity="0.5" />
    <circle cx="20" cy="180" r="8" fill="#F0396A" opacity="0.5" />
  </g>
</svg>

<style>
  .hero-float {
    animation: hero-float 5s ease-in-out infinite;
    transform-origin: center;
  }
  .hero-float-delayed {
    animation: hero-float 6s ease-in-out infinite;
    animation-delay: 0.8s;
    transform-origin: center;
  }
  .hero-float-slow {
    animation: hero-float 8s ease-in-out infinite;
    animation-delay: 0.3s;
    transform-origin: center;
  }

  @keyframes hero-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-float, .hero-float-delayed, .hero-float-slow {
      animation: none;
    }
  }
</style>
