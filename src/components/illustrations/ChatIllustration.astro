<svg viewBox="0 0 420 340" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-auto w-full" role="img" aria-label="Illustrazione di una conversazione con nuvolette di chat">
  <defs>
    <linearGradient id="chat-grad-1" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#ED7D31" />
      <stop offset="1" stop-color="#F0396A" />
    </linearGradient>
    <filter id="chat-shadow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="0" dy="10" stdDeviation="12" flood-color="#171717" flood-opacity="0.12" />
    </filter>
  </defs>

  <circle class="chat-float-slow" cx="210" cy="170" r="150" fill="#FFF4EC" opacity="0.6" />

  <g filter="url(#chat-shadow)" class="chat-float">
    <path d="M60 60h220a16 16 0 0 1 16 16v90a16 16 0 0 1-16 16H140l-38 32v-32H60a16 16 0 0 1-16-16V76a16 16 0 0 1 16-16Z" fill="white" />
    <rect x="80" y="90" width="150" height="10" rx="5" fill="#D8D8D8" />
    <rect x="80" y="112" width="190" height="10" rx="5" fill="#D8D8D8" />
    <rect x="80" y="134" width="100" height="10" rx="5" fill="#D8D8D8" />
  </g>

  <g filter="url(#chat-shadow)" class="chat-float-delayed">
    <path d="M360 130H210a16 16 0 0 0-16 16v70a16 16 0 0 0 16 16h110l30 26v-26h10a16 16 0 0 0 16-16v-70a16 16 0 0 0-16-16Z" fill="url(#chat-grad-1)" />
    <rect x="232" y="160" width="120" height="9" rx="4.5" fill="white" opacity="0.85" />
    <rect x="232" y="180" width="90" height="9" rx="4.5" fill="white" opacity="0.6" />
  </g>

  <g class="chat-float">
    <circle cx="365" cy="70" r="20" fill="white" filter="url(#chat-shadow)" />
    <path d="M357 70l5 5 9-10" stroke="#ED7D31" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none" />
  </g>

  <circle class="chat-float-slow" cx="40" cy="250" r="9" fill="#F0396A" opacity="0.5" />
  <circle class="chat-float-slow" cx="380" cy="280" r="12" fill="#ED7D31" opacity="0.4" />
</svg>

<style>
  .chat-float { animation: chat-float 5s ease-in-out infinite; transform-origin: center; }
  .chat-float-delayed { animation: chat-float 6s ease-in-out infinite; animation-delay: 0.5s; transform-origin: center; }
  .chat-float-slow { animation: chat-float 8s ease-in-out infinite; animation-delay: 0.2s; transform-origin: center; }
  @keyframes chat-float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-9px); } }
  @media (prefers-reduced-motion: reduce) {
    .chat-float, .chat-float-delayed, .chat-float-slow { animation: none; }
  }
</style>
