---
const features = [
  {
    icon: '⚡',
    title: 'Ultra-velocità',
    description: 'Facciamo di tutto per far caricare il tuo sito in un attimo — perché ogni secondo in più è un cliente che se ne va.',
  },
  {
    icon: '🗂️',
    title: 'Percorso chiaro',
    description: 'Sai sempre a che punto siamo: ti diciamo cosa ci serve da te e quando aspettarti ogni passaggio.',
  },
  {
    icon: '🖼️',
    title: 'Contenuti curati',
    description: 'Ottimizziamo immagini, testi e video perché siano belli da vedere e veloci da caricare, senza compromessi.',
  },
  {
    icon: '✨',
    title: 'Zero copia-incolla',
    description: 'Non rivendiamo lo stesso design a tutti. Ogni sito è pensato per la singola attività che lo userà.',
  },
];
---

<section class="container-page py-20 sm:py-28" aria-labelledby="why-heading">
  <div class="mx-auto max-w-2xl text-center" data-reveal>
    <span class="badge">Perché noi</span>
    <h2 id="why-heading" class="mt-4 text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
      4 buoni motivi per lavorare insieme
    </h2>
  </div>

  <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
    {features.map((f, i) => (
      <div class="rounded-3xl border border-ink-100 bg-white p-7" data-reveal style={`transition-delay: ${i * 80}ms; box-shadow: var(--shadow-card);`}>
        <span class="text-3xl">{f.icon}</span>
        <h3 class="mt-4 font-display text-lg font-semibold text-ink-900">{f.title}</h3>
        <p class="mt-2 text-sm leading-relaxed text-ink-500">{f.description}</p>
      </div>
    ))}
  </div>
</section>
