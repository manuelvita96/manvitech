---
---

<section class="container-page py-4 sm:py-6" aria-labelledby="compare-heading">
  <div class="mx-auto max-w-3xl text-center" data-reveal>
    <span class="badge">Prova tu stesso</span>
    <h2 id="compare-heading" class="mt-4 text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
      Trascina e guarda la differenza
    </h2>
    <p class="mt-4 text-ink-500">
      Non è solo una questione di gusti: velocità, ordine e ottimizzazione mobile sono quello che trasforma un visitatore in un cliente.
    </p>
  </div>

  <div class="mx-auto mt-10 max-w-3xl" data-reveal>
    <div
      class="compare-slider relative aspect-[4/5] w-full select-none overflow-hidden rounded-3xl border border-ink-100 sm:aspect-[16/9]"
      style="box-shadow: var(--shadow-card);"
    >
      <!-- DOPO: pulito, veloce, ottimizzato -->
      <div class="absolute inset-0 flex flex-col gap-4 bg-white p-6 sm:p-10">
        <div class="flex items-center justify-between">
          <div class="h-3 w-24 rounded-full" style="background: linear-gradient(90deg, var(--color-brand-500), var(--color-accent-500));"></div>
          <div class="flex gap-2">
            <div class="h-2 w-10 rounded-full bg-ink-100"></div>
            <div class="h-2 w-10 rounded-full bg-ink-100"></div>
            <div class="h-2 w-10 rounded-full bg-ink-100"></div>
          </div>
        </div>
        <div class="h-5 w-3/4 rounded-full bg-ink-800"></div>
        <div class="h-3 w-1/2 rounded-full bg-ink-200"></div>
        <div class="mt-1 h-9 w-32 rounded-full" style="background: linear-gradient(135deg, var(--color-brand-500), var(--color-accent-500));"></div>

        <div class="mt-auto grid grid-cols-3 gap-3">
          <div class="h-14 rounded-xl bg-ink-50"></div>
          <div class="h-14 rounded-xl bg-ink-50"></div>
          <div class="h-14 rounded-xl bg-ink-50"></div>
        </div>

        <!-- Badge dei vantaggi, tutti insieme -->
        <div class="mt-2 flex flex-wrap gap-2">
          <span class="compare-badge bg-ink-900 text-white">⚡ 0,3s</span>
          <span class="compare-badge bg-ink-900 text-white">📱 100% mobile</span>
          <span class="compare-badge bg-ink-900 text-white">🔍 Pronto per Google</span>
          <span class="compare-badge bg-ink-900 text-white">✓ Design curato</span>
        </div>
      </div>

      <!-- PRIMA: disordinato, lento, poco leggibile su mobile -->
      <div class="compare-before absolute inset-0 overflow-hidden bg-ink-100 p-4">
        <div class="flex items-center justify-between gap-2">
          <div class="h-6 w-20 bg-red-400"></div>
          <div class="h-6 w-16 bg-yellow-400"></div>
          <div class="h-6 w-6 rounded-full bg-blue-500"></div>
          <div class="h-6 w-14 bg-green-500"></div>
        </div>
        <div class="mt-2 flex gap-1">
          <div class="h-4 w-1/4" style="background: repeating-linear-gradient(45deg, #f0396a, #f0396a 4px, #ffd400 4px, #ffd400 8px);"></div>
          <div class="h-4 flex-1 bg-purple-500"></div>
        </div>
        <div class="mt-2 h-10 w-2/3 bg-ink-700"></div>
        <div class="mt-2 space-y-1">
          <div class="h-2 w-full bg-ink-400"></div>
          <div class="h-2 w-11/12 bg-ink-400"></div>
          <div class="h-2 w-full bg-ink-400"></div>
          <div class="h-2 w-4/5 bg-ink-400"></div>
        </div>
        <div class="mt-2 grid grid-cols-4 gap-1">
          <div class="h-10 bg-orange-400"></div>
          <div class="h-10 bg-teal-400"></div>
          <div class="h-10 bg-pink-400"></div>
          <div class="h-10 bg-lime-400"></div>
        </div>
        <span class="absolute right-3 top-16 rotate-6 rounded bg-yellow-300 px-2 py-0.5 text-[10px] font-bold text-ink-900 shadow">SALDI!!!</span>
        <span class="absolute left-3 bottom-24 -rotate-3 rounded bg-red-500 px-2 py-0.5 text-[10px] font-bold text-white shadow">CLICCA QUI</span>

        <!-- Badge dei problemi, tutti insieme -->
        <div class="absolute bottom-3 left-3 right-3 flex flex-wrap gap-2">
          <span class="compare-badge bg-ink-500 text-white">🐢 8,4s</span>
          <span class="compare-badge bg-ink-500 text-white">📵 Non responsive</span>
          <span class="compare-badge bg-ink-500 text-white">🚫 Introvabile su Google</span>
          <span class="compare-badge bg-ink-500 text-white">✗ Design confuso</span>
        </div>
      </div>

      <div class="compare-handle pointer-events-none absolute inset-y-0 flex w-0.5 -translate-x-1/2 items-center bg-white/80">
        <div class="pointer-events-none flex h-10 w-10 -translate-x-1/2 items-center justify-center rounded-full bg-white text-ink-700 shadow-lg">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7 4 12l4 5M16 7l4 5-4 5" /></svg>
        </div>
      </div>

      <input type="range" min="0" max="100" value="50" class="compare-range absolute inset-0 h-full w-full cursor-ew-resize opacity-0" aria-label="Trascina per confrontare un sito lento e disordinato con uno veloce, pulito e ottimizzato" />
    </div>
    <p class="mt-3 text-center text-xs text-ink-400">A sinistra il "prima", a destra il "dopo" — trascina per confrontare</p>
  </div>
</section>

<style>
  @reference "../../styles/global.css";
  .compare-badge {
    @apply rounded-full px-2.5 py-1 text-[11px] font-semibold backdrop-blur;
  }
</style>

<script>
  function initCompareSliders() {
    document.querySelectorAll<HTMLElement>('.compare-slider').forEach((wrapper) => {
      const range = wrapper.querySelector<HTMLInputElement>('.compare-range');
      const before = wrapper.querySelector<HTMLElement>('.compare-before');
      const handle = wrapper.querySelector<HTMLElement>('.compare-handle');
      if (!range || !before || !handle) return;

      const update = (value: number) => {
        before.style.clipPath = `inset(0 ${100 - value}% 0 0)`;
        handle.style.left = `${value}%`;
      };

      update(Number(range.value));
      range.addEventListener('input', () => update(Number(range.value)));
    });
  }

  initCompareSliders();
  document.addEventListener('astro:page-load', initCompareSliders);
</script>
