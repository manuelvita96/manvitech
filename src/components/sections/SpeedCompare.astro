---
---

<section class="container-page py-4 sm:py-6" aria-labelledby="compare-heading">
  <div class="mx-auto max-w-3xl text-center" data-reveal>
    <span class="badge">Prova tu stesso</span>
    <h2 id="compare-heading" class="mt-4 text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
      Trascina e guarda la differenza
    </h2>
    <p class="mt-4 text-ink-500">
      Non è solo una questione di gusti: un sito lento o disordinato perde clienti prima ancora che possano leggerti.
    </p>
  </div>

  <div class="mx-auto mt-8 flex justify-center gap-2" data-reveal>
    <button type="button" data-compare-tab="speed" class="compare-tab is-active" aria-pressed="true">
      Velocità
    </button>
    <button type="button" data-compare-tab="design" class="compare-tab" aria-pressed="false">
      Design
    </button>
  </div>

  <div class="mx-auto mt-8 max-w-3xl" data-reveal>
    <!-- PANNELLO 1: confronto velocità -->
    <div data-compare-panel="speed" class="compare-panel">
      <div
        class="compare-slider relative aspect-[16/10] w-full select-none overflow-hidden rounded-3xl border border-ink-100 sm:aspect-[16/8]"
        style="box-shadow: var(--shadow-card);"
      >
        <div class="absolute inset-0 flex flex-col justify-between bg-gradient-to-br from-ink-900 to-ink-950 p-6 sm:p-10">
          <div class="flex items-center justify-between">
            <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-semibold text-white">manvitech.it</span>
            <div class="flex h-9 w-9 items-center justify-center rounded-full text-white" style="background: linear-gradient(135deg, var(--color-brand-500), var(--color-accent-500));">
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.4"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
            </div>
          </div>
          <div>
            <p class="font-display text-4xl font-bold text-white sm:text-5xl">0,3<span class="text-brand-400">s</span></p>
            <p class="mt-1 text-sm text-ink-300">Caricamento completo · sito statico moderno</p>
            <div class="mt-4 h-2 w-full max-w-xs overflow-hidden rounded-full bg-white/10">
              <div class="h-full w-full rounded-full" style="background: linear-gradient(90deg, var(--color-brand-500), var(--color-accent-500));"></div>
            </div>
          </div>
        </div>

        <div class="compare-before absolute inset-0 flex flex-col justify-between overflow-hidden bg-ink-200 p-6 sm:p-10">
          <div class="flex items-center justify-between">
            <span class="rounded bg-ink-400 px-3 py-1 text-xs font-semibold text-white">sito-lento.it</span>
            <span class="rounded bg-red-500 px-2 py-1 text-[10px] font-bold text-white">PUBBLICITÀ</span>
          </div>
          <div>
            <p class="font-display text-4xl font-bold text-ink-600 sm:text-5xl">
              8,4<span class="text-ink-400">s</span>
              <svg class="ml-2 inline-block h-7 w-7 animate-spin text-ink-400" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="3" stroke-dasharray="40" stroke-linecap="round" opacity="0.5"/></svg>
            </p>
            <p class="mt-1 text-sm text-ink-500">Ancora in caricamento… plugin, script, tracker</p>
            <div class="mt-4 h-2 w-full max-w-xs overflow-hidden rounded-full bg-ink-300">
              <div class="h-full w-2/3 rounded-full bg-ink-400"></div>
            </div>
          </div>
        </div>

        <div class="compare-handle pointer-events-none absolute inset-y-0 flex w-0.5 -translate-x-1/2 items-center bg-white/80">
          <div class="pointer-events-none flex h-10 w-10 -translate-x-1/2 items-center justify-center rounded-full bg-white text-ink-700 shadow-lg">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7 4 12l4 5M16 7l4 5-4 5" /></svg>
          </div>
        </div>

        <input type="range" min="0" max="100" value="50" class="compare-range absolute inset-0 h-full w-full cursor-ew-resize opacity-0" aria-label="Trascina per confrontare la velocità di caricamento" />
      </div>
      <p class="mt-3 text-center text-xs text-ink-400">A sinistra il "prima", a destra il "dopo" — trascina per confrontare</p>
    </div>

    <!-- PANNELLO 2: confronto design -->
    <div data-compare-panel="design" class="compare-panel hidden">
      <div
        class="compare-slider relative aspect-[16/10] w-full select-none overflow-hidden rounded-3xl border border-ink-100 sm:aspect-[16/8]"
        style="box-shadow: var(--shadow-card);"
      >
        <!-- DOPO: pulito -->
        <div class="absolute inset-0 flex flex-col gap-4 bg-white p-6 sm:p-10">
          <div class="flex items-center justify-between">
            <div class="h-3 w-24 rounded-full" style="background: linear-gradient(90deg, var(--color-brand-500), var(--color-accent-500));"></div>
            <div class="flex gap-2">
              <div class="h-2 w-10 rounded-full bg-ink-100"></div>
              <div class="h-2 w-10 rounded-full bg-ink-100"></div>
              <div class="h-2 w-10 rounded-full bg-ink-100"></div>
            </div>
          </div>
          <div class="h-5 w-3/4 rounded-full bg-ink-800"></div>
          <div class="h-3 w-1/2 rounded-full bg-ink-200"></div>
          <div class="mt-2 h-9 w-32 rounded-full" style="background: linear-gradient(135deg, var(--color-brand-500), var(--color-accent-500));"></div>
          <div class="mt-auto grid grid-cols-3 gap-3">
            <div class="h-14 rounded-xl bg-ink-50"></div>
            <div class="h-14 rounded-xl bg-ink-50"></div>
            <div class="h-14 rounded-xl bg-ink-50"></div>
          </div>
        </div>

        <!-- PRIMA: disordinato -->
        <div class="compare-before absolute inset-0 overflow-hidden bg-ink-100 p-4">
          <div class="flex items-center justify-between gap-2">
            <div class="h-6 w-20 bg-red-400"></div>
            <div class="h-6 w-16 bg-yellow-400"></div>
            <div class="h-6 w-6 rounded-full bg-blue-500"></div>
            <div class="h-6 w-14 bg-green-500"></div>
          </div>
          <div class="mt-2 flex gap-1">
            <div class="h-4 w-1/4" style="background: repeating-linear-gradient(45deg, #f0396a, #f0396a 4px, #ffd400 4px, #ffd400 8px);"></div>
            <div class="h-4 flex-1 bg-purple-500"></div>
          </div>
          <div class="mt-2 h-10 w-2/3 bg-ink-700"></div>
          <div class="mt-2 space-y-1">
            <div class="h-2 w-full bg-ink-400"></div>
            <div class="h-2 w-11/12 bg-ink-400"></div>
            <div class="h-2 w-full bg-ink-400"></div>
            <div class="h-2 w-4/5 bg-ink-400"></div>
          </div>
          <div class="mt-2 grid grid-cols-4 gap-1">
            <div class="h-10 bg-orange-400"></div>
            <div class="h-10 bg-teal-400"></div>
            <div class="h-10 bg-pink-400"></div>
            <div class="h-10 bg-lime-400"></div>
          </div>
          <span class="absolute right-3 top-16 rotate-6 rounded bg-yellow-300 px-2 py-0.5 text-[10px] font-bold text-ink-900 shadow">SALDI!!!</span>
          <span class="absolute left-3 bottom-3 -rotate-3 rounded bg-red-500 px-2 py-0.5 text-[10px] font-bold text-white shadow">CLICCA QUI</span>
        </div>

        <div class="compare-handle pointer-events-none absolute inset-y-0 flex w-0.5 -translate-x-1/2 items-center bg-white/80">
          <div class="pointer-events-none flex h-10 w-10 -translate-x-1/2 items-center justify-center rounded-full bg-white text-ink-700 shadow-lg">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7 4 12l4 5M16 7l4 5-4 5" /></svg>
          </div>
        </div>

        <input type="range" min="0" max="100" value="50" class="compare-range absolute inset-0 h-full w-full cursor-ew-resize opacity-0" aria-label="Trascina per confrontare un design disordinato con uno pulito e moderno" />
      </div>
      <p class="mt-3 text-center text-xs text-ink-400">A sinistra un design confuso, a destra uno chiaro e curato — trascina per confrontare</p>
    </div>
  </div>
</section>

<style>
  .compare-tab {
    border-radius: 9999px;
    padding: 0.5rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-ink-500);
    border: 1px solid var(--color-ink-200);
    transition: all 0.2s ease;
  }
  .compare-tab.is-active {
    color: white;
    border-color: transparent;
    background: linear-gradient(135deg, var(--color-brand-500), var(--color-accent-500));
  }
</style>

<script>
  function initCompareTabs() {
    const tabs = document.querySelectorAll<HTMLButtonElement>('[data-compare-tab]');
    const panels = document.querySelectorAll<HTMLElement>('[data-compare-panel]');
    if (!tabs.length) return;

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.compareTab;
        tabs.forEach((t) => {
          const isActive = t === tab;
          t.classList.toggle('is-active', isActive);
          t.setAttribute('aria-pressed', String(isActive));
        });
        panels.forEach((p) => {
          p.classList.toggle('hidden', p.dataset.comparePanel !== target);
        });
      });
    });
  }

  function initCompareSliders() {
    document.querySelectorAll<HTMLElement>('.compare-slider').forEach((wrapper) => {
      const range = wrapper.querySelector<HTMLInputElement>('.compare-range');
      const before = wrapper.querySelector<HTMLElement>('.compare-before');
      const handle = wrapper.querySelector<HTMLElement>('.compare-handle');
      if (!range || !before || !handle) return;

      const update = (value: number) => {
        before.style.clipPath = `inset(0 ${100 - value}% 0 0)`;
        handle.style.left = `${value}%`;
      };

      update(Number(range.value));
      range.addEventListener('input', () => update(Number(range.value)));
    });
  }

  function init() {
    initCompareTabs();
    initCompareSliders();
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
