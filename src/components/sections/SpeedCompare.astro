---
---

<section class="container-page py-4 sm:py-6" aria-labelledby="compare-heading">
  <div class="mx-auto max-w-3xl text-center">
    <span class="badge">Prova tu stesso</span>
    <h2 id="compare-heading" class="mt-4 text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
      Trascina e guarda la differenza
    </h2>
    <p class="mt-4 text-ink-500">
      Non è solo una questione estetica: un sito lento perde clienti prima ancora che possano leggerti.
    </p>
  </div>

  <div class="mx-auto mt-10 max-w-3xl">
    <div
      id="speed-compare"
      class="relative aspect-[16/10] w-full select-none overflow-hidden rounded-3xl border border-ink-100 sm:aspect-[16/8]"
      style="box-shadow: var(--shadow-card);"
    >
      <!-- Pannello "DOPO": sempre visibile sotto -->
      <div class="absolute inset-0 flex flex-col justify-between bg-gradient-to-br from-ink-900 to-ink-950 p-6 sm:p-10">
        <div class="flex items-center justify-between">
          <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-semibold text-white">manvitech.it</span>
          <div
            class="flex h-9 w-9 items-center justify-center rounded-full text-white"
            style="background: linear-gradient(135deg, var(--color-brand-500), var(--color-accent-500));"
          >
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.4">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
            </svg>
          </div>
        </div>
        <div>
          <p class="font-display text-4xl font-bold text-white sm:text-5xl">0,3<span class="text-brand-400">s</span></p>
          <p class="mt-1 text-sm text-ink-300">Caricamento completo · sito statico moderno</p>
          <div class="mt-4 h-2 w-full max-w-xs overflow-hidden rounded-full bg-white/10">
            <div class="h-full w-full rounded-full" style="background: linear-gradient(90deg, var(--color-brand-500), var(--color-accent-500));"></div>
          </div>
        </div>
      </div>

      <!-- Pannello "PRIMA": tagliato via clip-path in base allo slider -->
      <div id="speed-compare-before" class="absolute inset-0 flex flex-col justify-between overflow-hidden bg-ink-200 p-6 sm:p-10">
        <div class="flex items-center justify-between">
          <span class="rounded bg-ink-400 px-3 py-1 text-xs font-semibold text-white">sito-lento.it</span>
          <span class="rounded bg-red-500 px-2 py-1 text-[10px] font-bold text-white">PUBBLICITÀ</span>
        </div>
        <div>
          <p class="font-display text-4xl font-bold text-ink-600 sm:text-5xl">
            8,4<span class="text-ink-400">s</span>
            <svg class="ml-2 inline-block h-7 w-7 animate-spin text-ink-400" viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="3" stroke-dasharray="40" stroke-linecap="round" opacity="0.5"/>
            </svg>
          </p>
          <p class="mt-1 text-sm text-ink-500">Ancora in caricamento… plugin, script, tracker</p>
          <div class="mt-4 h-2 w-full max-w-xs overflow-hidden rounded-full bg-ink-300">
            <div class="h-full w-2/3 rounded-full bg-ink-400"></div>
          </div>
        </div>
      </div>

      <!-- Maniglia -->
      <div id="speed-compare-handle" class="pointer-events-none absolute inset-y-0 flex w-0.5 -translate-x-1/2 items-center bg-white/80">
        <div class="pointer-events-none flex h-10 w-10 -translate-x-1/2 items-center justify-center rounded-full bg-white text-ink-700 shadow-lg">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7 4 12l4 5M16 7l4 5-4 5" />
          </svg>
        </div>
      </div>

      <input
        id="speed-compare-range"
        type="range"
        min="0"
        max="100"
        value="50"
        aria-label="Trascina per confrontare la velocità di caricamento tra un sito lento e un sito Manvitech"
        class="absolute inset-0 h-full w-full cursor-ew-resize opacity-0"
      />
    </div>
    <p class="mt-3 text-center text-xs text-ink-400">A sinistra il "prima", a destra il "dopo" — trascina per confrontare</p>
  </div>
</section>

<script>
  function initSpeedCompare() {
    const wrapper = document.getElementById('speed-compare');
    const range = document.getElementById('speed-compare-range') as HTMLInputElement | null;
    const before = document.getElementById('speed-compare-before');
    const handle = document.getElementById('speed-compare-handle');
    if (!wrapper || !range || !before || !handle) return;

    const update = (value: number) => {
      before.style.clipPath = `inset(0 ${100 - value}% 0 0)`;
      handle.style.left = `${value}%`;
    };

    update(Number(range.value));
    range.addEventListener('input', () => update(Number(range.value)));
  }

  initSpeedCompare();
  document.addEventListener('astro:page-load', initSpeedCompare);
</script>
