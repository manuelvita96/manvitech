---
---

<section class="container-page py-20 sm:py-28" aria-labelledby="showcase-heading">
  <div class="mx-auto max-w-2xl text-center" data-reveal>
    <span class="badge">Un esempio, non un cliente</span>
    <h2 id="showcase-heading" class="mt-4 text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
      Ecco il tipo di sito che costruiamo
    </h2>
    <p class="mt-4 text-ink-500">
      Non mostriamo lavori di clienti reali, ma questo dimostrativo rende bene l'idea: pulito, veloce, pensato per convertire.
    </p>
  </div>

  <div class="mx-auto mt-14 max-w-3xl" data-reveal="scale" data-parallax="0.04">
    <!-- Cornice laptop -->
    <div class="rounded-t-2xl border-x-[10px] border-t-[10px] border-ink-900 bg-ink-900 sm:border-x-[14px] sm:border-t-[14px]" style="box-shadow: var(--shadow-card);">
      <!-- Barra del "browser" -->
      <div class="flex items-center gap-1.5 rounded-t-lg bg-ink-800 px-3 py-2">
        <span class="h-2 w-2 rounded-full bg-red-400/70"></span>
        <span class="h-2 w-2 rounded-full bg-yellow-400/70"></span>
        <span class="h-2 w-2 rounded-full bg-green-400/70"></span>
        <span class="ml-2 truncate rounded bg-ink-700 px-3 py-0.5 text-[10px] text-ink-300">tuositosupermisura.it</span>
      </div>

      <!-- Contenuto demo -->
      <div class="aspect-[16/10] w-full overflow-hidden bg-white sm:aspect-[16/9]">
        <div class="flex h-full flex-col p-4 sm:p-8">
          <div class="flex items-center justify-between">
            <div class="h-3 w-16 rounded-full sm:h-3.5 sm:w-20" style="background: linear-gradient(90deg, var(--color-brand-500), var(--color-accent-500));"></div>
            <div class="hidden gap-3 sm:flex">
              <div class="h-2 w-10 rounded-full bg-ink-100"></div>
              <div class="h-2 w-10 rounded-full bg-ink-100"></div>
              <div class="h-2 w-10 rounded-full bg-ink-100"></div>
            </div>
            <div class="h-6 w-16 rounded-full sm:h-7 sm:w-20" style="background: linear-gradient(135deg, var(--color-brand-500), var(--color-accent-500));"></div>
          </div>

          <div class="mt-6 flex flex-1 flex-col justify-center gap-3 sm:mt-10">
            <div class="h-4 w-3/5 rounded-full bg-ink-800 sm:h-6"></div>
            <div class="h-4 w-2/5 rounded-full bg-ink-800 sm:h-6"></div>
            <div class="mt-2 h-2.5 w-4/5 rounded-full bg-ink-200 sm:w-3/5"></div>
            <div class="mt-3 h-8 w-28 rounded-full sm:h-9 sm:w-32" style="background: linear-gradient(135deg, var(--color-brand-500), var(--color-accent-500));"></div>
          </div>

          <div class="mt-6 grid grid-cols-3 gap-2 sm:gap-4">
            <div class="aspect-square rounded-lg bg-brand-50 sm:rounded-xl"></div>
            <div class="aspect-square rounded-lg bg-ink-50 sm:rounded-xl"></div>
            <div class="aspect-square rounded-lg bg-brand-50 sm:rounded-xl"></div>
          </div>
        </div>
      </div>
    </div>
    <!-- Base laptop -->
    <div class="mx-auto h-3 w-[104%] max-w-none -translate-x-[2%] rounded-b-xl bg-ink-800 sm:h-4" style="box-shadow: var(--shadow-card);"></div>
    <div class="mx-auto h-1.5 w-1/3 rounded-b-2xl bg-ink-700"></div>
  </div>
</section>
