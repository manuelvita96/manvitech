---
---

<section class="container-page py-20 sm:py-28" aria-labelledby="showcase-heading">
  <div class="mx-auto max-w-2xl text-center" data-reveal>
    <span class="badge">Un esempio, non un cliente</span>
    <h2 id="showcase-heading" class="mt-4 text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
      Ecco il tipo di sito che costruiamo
    </h2>
    <p class="mt-4 text-ink-500">
      Non mostriamo lavori di clienti reali, ma questo dimostrativo rende bene l'idea: pulito, veloce, pensato per convertire.
    </p>
  </div>

  <div class="mx-auto mt-14 max-w-3xl" data-reveal="scale" data-parallax="0.04">
    <!-- Cornice laptop -->
    <div class="rounded-t-2xl border-x-[10px] border-t-[10px] border-ink-900 bg-ink-900 sm:border-x-[14px] sm:border-t-[14px]" style="box-shadow: var(--shadow-card);">
      <!-- Barra del "browser" -->
      <div class="flex items-center gap-1.5 rounded-t-lg bg-ink-800 px-3 py-2">
        <span class="h-2 w-2 rounded-full bg-red-400/70"></span>
        <span class="h-2 w-2 rounded-full bg-yellow-400/70"></span>
        <span class="h-2 w-2 rounded-full bg-green-400/70"></span>
        <span class="ml-2 truncate rounded bg-ink-700 px-3 py-0.5 text-[10px] text-ink-300">tuositosupermisura.it</span>
      </div>

      <!-- Contenuto demo: testo vero al posto dei placeholder grigi, per dare
           l'idea concreta di un sito funzionante e non di un semplice mockup. -->
      <div class="aspect-[16/10] w-full overflow-hidden bg-white sm:aspect-[16/9]">
        <div class="flex h-full flex-col p-4 sm:p-8">
          <div class="flex items-center justify-between">
            <span class="font-display text-sm font-bold text-ink-900 sm:text-base" style="background: linear-gradient(90deg, var(--color-brand-500), var(--color-accent-500)); -webkit-background-clip: text; background-clip: text; color: transparent;">
              Bottega Verde
            </span>
            <div class="hidden gap-4 text-[10px] font-medium text-ink-400 sm:flex">
              <span>Chi siamo</span>
              <span>Prodotti</span>
              <span>Contatti</span>
            </div>
            <div class="rounded-full px-3 py-1.5 text-[10px] font-semibold text-white sm:px-4 sm:py-2 sm:text-xs" style="background: linear-gradient(135deg, var(--color-brand-500), var(--color-accent-500));">
              Contattaci
            </div>
          </div>

          <div class="mt-6 flex flex-1 flex-col justify-center gap-2 sm:mt-10 sm:gap-3">
            <h3 class="text-lg font-bold leading-tight text-ink-900 sm:text-3xl">
              Prodotti tipici,<br />portati online.
            </h3>
            <p class="mt-1 max-w-xs text-[11px] leading-snug text-ink-400 sm:text-sm">
              Scopri la selezione di prodotti a km 0 e ordina comodamente da casa, con consegna in giornata.
            </p>
            <div class="mt-3 inline-flex w-fit rounded-full px-4 py-2 text-[11px] font-semibold text-white sm:px-6 sm:py-2.5 sm:text-sm" style="background: linear-gradient(135deg, var(--color-brand-500), var(--color-accent-500));">
              Scopri i prodotti
            </div>
          </div>

          <div class="mt-6 grid grid-cols-3 gap-2 sm:gap-4">
            <div class="flex aspect-square flex-col justify-end rounded-lg bg-brand-50 p-2 sm:rounded-xl sm:p-3">
              <span class="text-[9px] font-semibold text-ink-700 sm:text-xs">Olio EVO</span>
            </div>
            <div class="flex aspect-square flex-col justify-end rounded-lg bg-ink-50 p-2 sm:rounded-xl sm:p-3">
              <span class="text-[9px] font-semibold text-ink-700 sm:text-xs">Vino Chianti</span>
            </div>
            <div class="flex aspect-square flex-col justify-end rounded-lg bg-brand-50 p-2 sm:rounded-xl sm:p-3">
              <span class="text-[9px] font-semibold text-ink-700 sm:text-xs">Miele bio</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- Base laptop -->
    <div class="mx-auto h-3 w-[104%] max-w-none -translate-x-[2%] rounded-b-xl bg-ink-800 sm:h-4" style="box-shadow: var(--shadow-card);"></div>
    <div class="mx-auto h-1.5 w-1/3 rounded-b-2xl bg-ink-700"></div>
  </div>
</section>
