---
import HeroIllustration from '../illustrations/HeroIllustration.astro';
---

<section class="relative overflow-hidden pt-16 pb-20 sm:pt-20 sm:pb-28">
  <!-- Sfondo interattivo: griglia di punti che reagisce al movimento del cursore -->
  <canvas id="hero-canvas" class="pointer-events-none absolute inset-0 h-full w-full opacity-70" aria-hidden="true"></canvas>

  <!-- Blob decorativo organico, sfumato tra i colori del brand -->
  <div
    aria-hidden="true"
    class="blob pointer-events-none absolute -right-32 -top-24 h-[520px] w-[520px] opacity-30 blur-3xl sm:opacity-40"
    style="background: linear-gradient(135deg, var(--color-brand-400), var(--color-accent-500));"
  >
  </div>
  <div
    aria-hidden="true"
    class="blob pointer-events-none absolute -left-40 bottom-0 h-[380px] w-[380px] opacity-20 blur-3xl"
    style="background: linear-gradient(135deg, var(--color-brand-300), var(--color-brand-500));"
  >
  </div>

  <div class="container-page relative grid items-center gap-12 lg:grid-cols-2 lg:gap-8">
    <div class="text-center lg:text-left">
      <span class="badge" data-reveal>
        <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>
        Siti internet · SEO · Social
      </span>

      <h1 class="mt-6 text-4xl font-bold leading-[1.08] tracking-tight text-ink-900 sm:text-6xl" data-reveal style="transition-delay: 80ms;">
        Hai un'idea?<br class="hidden lg:block" />
        Portiamola <span class="text-gradient">online sul serio</span>
      </h1>

      <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-ink-500 lg:mx-0" data-reveal style="transition-delay: 160ms;">
        Ti costruiamo un sito veloce, curato nei minimi dettagli e pensato per portarti
        clienti veri — non solo bello da guardare. Zero paroloni tecnici, solo risultati.
      </p>

      <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row lg:justify-start" data-reveal style="transition-delay: 240ms;">
        <a href="/contatti" class="btn-primary w-full sm:w-auto">Inizia il tuo progetto</a>
        <a href="/servizi" class="btn-ghost w-full sm:w-auto">Scopri come lavoriamo</a>
      </div>

      <dl class="mx-auto mt-16 grid max-w-2xl grid-cols-3 gap-6 border-t border-ink-100 pt-8 lg:mx-0" data-reveal style="transition-delay: 320ms;">
        <div>
          <dt class="sr-only">Punteggio prestazioni</dt>
          <dd class="font-display text-3xl font-bold text-ink-900">100<span class="text-brand-500">/100</span></dd>
          <p class="mt-1 text-xs text-ink-400">Performance web</p>
        </div>
        <div>
          <dt class="sr-only">Siti realizzati</dt>
          <dd class="font-display text-3xl font-bold text-ink-900">50<span class="text-brand-500">+</span></dd>
          <p class="mt-1 text-xs text-ink-400">Progetti realizzati</p>
        </div>
        <div>
          <dt class="sr-only">Tempo medio di risposta</dt>
          <dd class="font-display text-3xl font-bold text-ink-900">24<span class="text-brand-500">h</span></dd>
          <p class="mt-1 text-xs text-ink-400">Tempo di risposta</p>
        </div>
      </dl>
    </div>

    <div class="mx-auto w-full max-w-md lg:max-w-none" data-reveal="scale" data-parallax="0.06" style="transition-delay: 200ms;">
      <HeroIllustration />
    </div>
  </div>
</section>

<script>
  // Sfondo interattivo nell'hero: una griglia di punti che si "allontanano"
  // leggermente dal cursore, per un effetto sottile ma memorabile.
  function initHeroCanvas() {
    const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const section = canvas.closest('section') as HTMLElement;
    let width = 0;
    let height = 0;
    let dots: { x: number; y: number; baseX: number; baseY: number }[] = [];
    let mouse = { x: -9999, y: -9999 };
    let raf = 0;
    let running = false;

    const SPACING = 42;
    const RADIUS = 90;

    function resize() {
      width = canvas.width = section.offsetWidth * devicePixelRatio;
      height = canvas.height = section.offsetHeight * devicePixelRatio;
      canvas.style.width = `${section.offsetWidth}px`;
      canvas.style.height = `${section.offsetHeight}px`;

      dots = [];
      const cols = Math.ceil(width / (SPACING * devicePixelRatio));
      const rows = Math.ceil(height / (SPACING * devicePixelRatio));
      for (let i = 0; i <= cols; i++) {
        for (let j = 0; j <= rows; j++) {
          const x = i * SPACING * devicePixelRatio;
          const y = j * SPACING * devicePixelRatio;
          dots.push({ x, y, baseX: x, baseY: y });
        }
      }
    }

    function draw() {
      ctx!.clearRect(0, 0, width, height);
      const r = RADIUS * devicePixelRatio;

      for (const dot of dots) {
        const dx = dot.baseX - mouse.x;
        const dy = dot.baseY - mouse.y;
        const dist = Math.sqrt(dx * dx + dy * dy);

        if (dist < r) {
          const force = (1 - dist / r) * 14 * devicePixelRatio;
          const angle = Math.atan2(dy, dx);
          dot.x = dot.baseX + Math.cos(angle) * force;
          dot.y = dot.baseY + Math.sin(angle) * force;
        } else {
          dot.x += (dot.baseX - dot.x) * 0.12;
          dot.y += (dot.baseY - dot.y) * 0.12;
        }

        const closeness = Math.max(0, 1 - dist / r);
        const size = (1.4 + closeness * 1.8) * devicePixelRatio;
        ctx!.beginPath();
        ctx!.arc(dot.x, dot.y, size, 0, Math.PI * 2);
        ctx!.fillStyle = closeness > 0 ? `rgba(237, 125, 49, ${0.25 + closeness * 0.5})` : 'rgba(123, 123, 123, 0.16)';
        ctx!.fill();
      }

      raf = requestAnimationFrame(draw);
    }

    function start() {
      if (running) return;
      running = true;
      raf = requestAnimationFrame(draw);
    }
    function stop() {
      running = false;
      cancelAnimationFrame(raf);
    }

    resize();
    start();

    window.addEventListener('resize', resize);
    section.addEventListener('mousemove', (e) => {
      const rect = section.getBoundingClientRect();
      mouse.x = (e.clientX - rect.left) * devicePixelRatio;
      mouse.y = (e.clientY - rect.top) * devicePixelRatio;
    });
    section.addEventListener('mouseleave', () => {
      mouse.x = -9999;
      mouse.y = -9999;
    });

    // Ferma l'animazione quando l'hero non è visibile (risparmio risorse)
    new IntersectionObserver(([entry]) => {
      entry.isIntersecting ? start() : stop();
    }).observe(section);
  }

  initHeroCanvas();
  document.addEventListener('astro:page-load', initHeroCanvas);
</script>
