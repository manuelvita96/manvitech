---
const services = [
  {
    title: 'Siti internet',
    description: 'Un sito che si carica in un lampo e sta bene su ogni schermo, dal telefono al monitor.',
    href: '/servizi/siti-internet',
    icon: 'globe',
  },
  {
    title: 'Consulenza sito esistente',
    description: 'Hai già un sito? Lo analizziamo e ti diciamo cosa non va e come sistemarlo.',
    href: '/servizi/consulenza-sito-esistente',
    icon: 'wrench',
  },
  {
    title: 'SEO & visibilità AI',
    description: 'Ti facciamo trovare su Google, e sempre di più anche da ChatGPT e simili.',
    href: '/servizi/seo',
    icon: 'search',
  },
  {
    title: 'Social media',
    description: 'Ci pensiamo noi ai tuoi social, con una strategia vera, non post a caso.',
    href: '/servizi/social',
    icon: 'share',
  },
  {
    title: 'Graphic design',
    description: 'Un\'immagine coordinata che si riconosce a colpo d\'occhio, ovunque la vedano.',
    href: '/servizi/design',
    icon: 'palette',
  },
  {
    title: 'Manutenzione',
    description: 'Aggiornamenti, controlli e piccole modifiche: ci pensiamo noi, mese dopo mese.',
    href: '/servizi/manutenzione-e-assistenza',
    icon: 'shield',
  },
];

const icons: Record<string, string> = {
  globe: 'M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18ZM3.6 9h16.8M3.6 15h16.8M12 3a15 15 0 0 1 0 18 15 15 0 0 1 0-18Z',
  search: 'm21 21-4.35-4.35M19 11a8 8 0 1 1-16 0 8 8 0 0 1 16 0Z',
  share: 'M8.7 10.7 15.3 7.3M8.7 13.3l6.6 3.4M7 14a3 3 0 1 0 0-4 3 3 0 0 0 0 4ZM17 7a3 3 0 1 0 0-4 3 3 0 0 0 0 4ZM17 21a3 3 0 1 0 0-4 3 3 0 0 0 0 4Z',
  palette: 'M12 3a9 9 0 1 0 0 18c1 0 1.5-.6 1.5-1.5 0-.4-.15-.75-.4-1.05-.24-.3-.4-.65-.4-1.05 0-.9.7-1.5 1.6-1.5H16a4 4 0 0 0 4-4c0-4.4-3.6-8-8-8ZM7 12a1 1 0 1 0 0-2 1 1 0 0 0 0 2ZM10 8a1 1 0 1 0 0-2 1 1 0 0 0 0 2ZM15 8a1 1 0 1 0 0-2 1 1 0 0 0 0 2ZM17 12a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z',
  wrench: 'M14.7 6.3a4 4 0 0 0-5.6 4.6L3 17l3 3 6.1-6.1a4 4 0 0 0 4.6-5.6l-2.6 2.6-2-2 2.6-2.6Z',
  shield: 'M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3ZM9.5 12l1.8 1.8L15 10',
};
---

<section class="container-page py-20 sm:py-28" aria-labelledby="services-heading">
  <div class="mx-auto max-w-2xl text-center">
    <span class="badge" data-reveal>Cosa facciamo</span>
    <h2 id="services-heading" class="mt-4 text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl" data-reveal>
      Tutto quello che ti serve per farti notare
    </h2>
    <p class="mt-4 text-ink-500" data-reveal style="transition-delay: 80ms;">
      Un solo punto di riferimento per il sito, la visibilità e i social. Senza rimpalli tra fornitori diversi.
    </p>
  </div>

  <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {services.map((service, i) => (
      <a
        href={service.href}
        data-reveal
        style={`transition-delay: ${i * 70}ms; box-shadow: var(--shadow-card);`}
        class="group relative flex flex-col rounded-3xl border border-ink-100 bg-white p-7 transition-all duration-300 hover:-translate-y-1"
      >
        <div
          class="flex h-12 w-12 items-center justify-center rounded-2xl text-white transition-transform duration-300 group-hover:scale-110"
          style="background: linear-gradient(135deg, var(--color-brand-400), var(--color-accent-500));"
        >
          <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d={icons[service.icon]} />
          </svg>
        </div>
        <h3 class="mt-5 font-display text-lg font-semibold text-ink-900">{service.title}</h3>
        <p class="mt-2 text-sm leading-relaxed text-ink-500">{service.description}</p>
        <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-600">
          Scopri di più
          <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </span>
      </a>
    ))}
  </div>
</section>
