---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);

const dateFormatter = new Intl.DateTimeFormat('it-IT', { day: 'numeric', month: 'long', year: 'numeric' });
---

{posts.length > 0 && (
  <section class="bg-ink-50/60 py-20 sm:py-28" aria-labelledby="blog-heading">
    <div class="container-page">
      <div class="flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-end">
        <div>
          <span class="badge">Dal blog</span>
          <h2 id="blog-heading" class="mt-4 text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
            Consigli e novità
          </h2>
        </div>
        <a href="/blog" class="btn-ghost">Tutti gli articoli</a>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group flex flex-col overflow-hidden rounded-3xl bg-white transition-all duration-300 hover:-translate-y-1"
            style="box-shadow: var(--shadow-card);"
          >
            <div class="aspect-[16/10] w-full bg-gradient-to-br from-brand-100 to-accent-400/20"></div>
            <div class="flex flex-1 flex-col p-6">
              <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{post.data.category}</span>
              <h3 class="mt-2 font-display text-lg font-semibold leading-snug text-ink-900 group-hover:text-brand-600">
                {post.data.title}
              </h3>
              <p class="mt-2 line-clamp-2 text-sm text-ink-500">{post.data.description}</p>
              <time datetime={post.data.pubDate.toISOString()} class="mt-4 text-xs text-ink-400">
                {dateFormatter.format(post.data.pubDate)}
              </time>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}
