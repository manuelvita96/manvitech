---
const paths = [
  {
    tag: 'Per iniziare',
    title: 'Il necessario, fatto bene',
    description: 'Perfetto se vuoi partire con una base solida, senza fronzoli superflui.',
    items: ['Sito vetrina responsive', 'Testi e immagini ottimizzati', 'Impostazione SEO di base', 'Segnalazione ai motori di ricerca'],
    highlighted: false,
  },
  {
    tag: 'Soluzione completa',
    title: 'Tutto quello che ti serve',
    description: "Per chi vuole affidarsi e non pensarci più: sito, contenuti e visibilità gestiti insieme.",
    items: ['Sito su misura + blog', 'Strategia SEO continuativa', 'Gestione dei social network', 'Manutenzione e assistenza inclusa'],
    highlighted: true,
  },
];
---

<section class="container-page py-20 sm:py-28" aria-labelledby="paths-heading">
  <div class="mx-auto max-w-2xl text-center" data-reveal>
    <span class="badge">Come iniziare</span>
    <h2 id="paths-heading" class="mt-4 text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
      Scegli il punto di partenza
    </h2>
    <p class="mt-4 text-ink-500">
      Perché pagare tanti fornitori diversi? Un solo referente, un percorso chiaro, nessuna sorpresa nei costi.
    </p>
  </div>

  <div class="mx-auto mt-14 grid max-w-3xl gap-6 sm:grid-cols-2">
    {paths.map((path, i) => (
      <div
        data-reveal
        style={`transition-delay: ${i * 100}ms; ${path.highlighted ? 'background: linear-gradient(150deg, var(--color-ink-900), var(--color-ink-950));' : ''}`}
        class={`relative rounded-3xl border p-8 ${path.highlighted ? 'border-transparent text-white' : 'border-ink-100 bg-white'}`}
      >
        {path.highlighted && (
          <span class="absolute -top-3 right-6 rounded-full px-3 py-1 text-xs font-semibold text-white" style="background: linear-gradient(135deg, var(--color-brand-500), var(--color-accent-500));">
            Il più scelto
          </span>
        )}
        <span class={`text-xs font-semibold uppercase tracking-wide ${path.highlighted ? 'text-brand-400' : 'text-brand-600'}`}>{path.tag}</span>
        <h3 class={`mt-2 font-display text-xl font-semibold ${path.highlighted ? 'text-white' : 'text-ink-900'}`}>{path.title}</h3>
        <p class={`mt-2 text-sm ${path.highlighted ? 'text-ink-300' : 'text-ink-500'}`}>{path.description}</p>

        <ul class="mt-6 space-y-2.5">
          {path.items.map((item) => (
            <li class={`flex items-start gap-2.5 text-sm ${path.highlighted ? 'text-ink-200' : 'text-ink-600'}`}>
              <svg class={`mt-0.5 h-4 w-4 shrink-0 ${path.highlighted ? 'text-brand-400' : 'text-brand-500'}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
              {item}
            </li>
          ))}
        </ul>

        <a
          href="/contatti"
          class={path.highlighted ? 'btn-primary mt-8 w-full' : 'btn-ghost mt-8 w-full'}
        >
          Chiedi un preventivo
        </a>
      </div>
    ))}
  </div>
</section>
