---
// Componente centrale per SEO + visibilità AI (JSON-LD, OG, Twitter, canonical).
// Ogni pagina passa i propri dati: il resto (Organization, sitename, ecc.) è gestito qui.

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article' | 'profile';
  noindex?: boolean;
  jsonLd?: Record<string, any> | Record<string, any>[];
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  title,
  description,
  image = '/images/og-default.jpg',
  type = 'website',
  noindex = false,
  jsonLd,
  publishedTime,
  modifiedTime,
} = Astro.props;

const siteName = 'Manvitech';
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const absoluteImage = new URL(image, Astro.site);
const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;

// Organization schema: presente su ogni pagina per rafforzare l'entità
// riconosciuta da motori di ricerca e sistemi AI (Google, Bing, ChatGPT, Perplexity...).
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': 'https://manvitech.it/#organization',
  name: 'Manvitech',
  legalName: 'Manvitech di Vita Manuel',
  url: 'https://manvitech.it',
  logo: new URL('/images/logo.png', Astro.site).toString(),
  image: new URL('/images/og-default.jpg', Astro.site).toString(),
  description:
    'Realizzazione siti internet, gestione social e consulenza SEO per attività e professionisti.',
  telephone: '+39-345-0639886',
  email: 'info@manvitech.it',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Via Casabianca 28',
    addressLocality: 'Fucecchio',
    postalCode: '50054',
    addressRegion: 'FI',
    addressCountry: 'IT',
  },
  sameAs: [
    'https://facebook.com/manvitech',
    'https://instagram.com/manvitech',
    'https://twitter.com/manvitech',
  ],
};

const schemas = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={absoluteImage} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content="it_IT" />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={absoluteImage} />

<!-- Structured data: Organization sempre presente + schemi specifici della pagina -->
<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
{
  schemas.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))
}
