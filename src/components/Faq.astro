---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
  title?: string;
  subtitle?: string;
  compact?: boolean;
}

const { items, title = 'Domande frequenti', subtitle, compact = false } = Astro.props;

// Schema FAQPage: aiuta sia la SERP (rich snippet) sia gli assistenti AI
// a rispondere direttamente con le tue risposte quando qualcuno chiede.
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

{items.length > 0 && (
  <section class={compact ? '' : 'container-page py-16 sm:py-24'} aria-labelledby="faq-heading">
    {!compact && (
      <div class="mx-auto max-w-2xl text-center" data-reveal>
        <span class="badge">Domande frequenti</span>
        <h2 id="faq-heading" class="mt-4 text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
          {title}
        </h2>
        {subtitle && <p class="mt-4 text-ink-500">{subtitle}</p>}
      </div>
    )}

    <div class={compact ? 'space-y-3' : 'mx-auto mt-12 max-w-2xl space-y-3'} data-reveal>
      {items.map((item) => (
        <details class="group rounded-2xl border border-ink-100 bg-white p-5 open:border-brand-200 open:bg-brand-50/30 [&_summary::-webkit-details-marker]:hidden">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-display text-base font-semibold text-ink-900">
            {item.question}
            <svg class="h-5 w-5 shrink-0 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
          </summary>
          <p class="mt-3 text-sm leading-relaxed text-ink-500">{item.answer}</p>
        </details>
      ))}
    </div>

    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </section>
)}
