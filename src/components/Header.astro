---
const navItems = [
  { label: 'Servizi', href: '/servizi' },
  { label: 'Blog', href: '/blog' },
  { label: 'Chi siamo', href: '/chi-siamo' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-ink-100/80 bg-white/80 backdrop-blur-lg">
  <div class="container-page flex h-18 items-center justify-between py-3.5">
    <a href="/" class="flex items-center gap-2 shrink-0" aria-label="Manvitech, torna alla home">
      <img src="/images/logo.png" alt="Manvitech" class="h-8 w-auto sm:h-9" width="140" height="40" />
    </a>

    <nav class="hidden items-center gap-1 lg:flex" aria-label="Navigazione principale">
      {navItems.map((item) => {
        const isActive = currentPath === item.href || currentPath.startsWith(item.href + '/');
        return (
          <a
            href={item.href}
            class:list={[
              'rounded-full px-4 py-2 text-sm font-medium transition-colors',
              isActive ? 'text-brand-600 bg-brand-50' : 'text-ink-600 hover:text-brand-600 hover:bg-ink-50',
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <div class="hidden shrink-0 lg:block">
      <a href="/contatti" class="btn-primary">Parliamo del tuo progetto</a>
    </div>

    <button
      id="menu-toggle"
      type="button"
      class="flex h-10 w-10 items-center justify-center rounded-full text-ink-700 lg:hidden"
      aria-label="Apri il menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg id="icon-open" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
      </svg>
      <svg id="icon-close" class="hidden h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <nav
    id="mobile-menu"
    class="hidden max-h-[calc(100vh-4.5rem)] overflow-y-auto border-t border-ink-100 bg-white lg:hidden"
    aria-label="Navigazione mobile"
  >
    <div class="container-page flex flex-col gap-1 py-4">
      {navItems.map((item) => (
        <a href={item.href} class="rounded-xl px-4 py-3 text-base font-medium text-ink-700 hover:bg-ink-50">
          {item.label}
        </a>
      ))}
      <a href="/contatti" class="btn-primary mt-2 w-full">Parliamo del tuo progetto</a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden') === false;
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
