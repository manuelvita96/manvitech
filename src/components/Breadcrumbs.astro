---
interface Crumb {
  label: string;
  href: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;

// items non include "Home": la aggiungiamo sempre come primo nodo.
const allItems = [{ label: 'Home', href: '/' }, ...items];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: allItems.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.label,
    item: new URL(item.href, Astro.site).toString(),
  })),
};
---

<nav aria-label="Breadcrumb" class="container-page pt-6">
  <ol class="flex flex-wrap items-center gap-1.5 text-xs text-ink-400">
    {allItems.map((item, index) => (
      <li class="flex items-center gap-1.5">
        {index > 0 && <span aria-hidden="true">/</span>}
        {index === allItems.length - 1 ? (
          <span class="font-medium text-ink-600" aria-current="page">{item.label}</span>
        ) : (
          <a href={item.href} class="hover:text-brand-600">{item.label}</a>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
