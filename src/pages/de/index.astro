---
import Layout from '../../layouts/Layout.astro';

// Landing page DE indipendente (non un sito tradotto integralmente):
// pensata per intercettare ricerche in tedesco da turisti e clienti
// di lingua tedesca, molto presenti in Toscana (San Miniato, Vinci, ecc.).
---

<Layout
  title="Manvitech — Webseiten, SEO & Social Media (Toskana, Italien)"
  description="Manvitech gestaltet schnelle, moderne Webseiten und SEO-Strategien für Unternehmen in der Toskana, in der Nähe von Fucecchio, San Miniato und Vinci."
>
  <section class="container-page py-20 sm:py-28">
    <div class="mx-auto max-w-2xl text-center">
      <span class="badge">Webagentur in der Toskana</span>
      <h1 class="mt-6 text-4xl font-bold tracking-tight text-ink-900 sm:text-5xl">
        Webseiten, die aus Ideen <span class="text-gradient">echte Kunden machen</span>
      </h1>
      <p class="mx-auto mt-6 max-w-xl text-lg text-ink-500">
        Wir gestalten schnelle, moderne und maßgeschneiderte Webseiten für Unternehmen und
        Selbstständige in der Toskana — dazu SEO- und Social-Media-Strategien, damit Sie online
        gefunden werden.
      </p>
      <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="mailto:info@manvitech.it" class="btn-primary w-full sm:w-auto">Kontakt aufnehmen</a>
        <a href="/" class="btn-ghost w-full sm:w-auto">Italienische Version</a>
      </div>
    </div>
  </section>
</Layout>
