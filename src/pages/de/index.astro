---
import Layout from '../../layouts/Layout.astro';
import HreflangLinks from '../../components/HreflangLinks.astro';
import HeroLang from '../../components/sections/HeroLang.astro';

// Landing page DE indipendente (non un sito tradotto integralmente):
// pensata per intercettare ricerche in tedesco da turisti e clienti
// di lingua tedesca, molto presenti in Toscana (San Miniato, Vinci, ecc.).
---

<Layout
  lang="de"
  title="Manvitech — Webseiten, SEO & Social Media (Toskana, Italien)"
  description="Manvitech gestaltet schnelle, moderne Webseiten und SEO-Strategien für Unternehmen in der Toskana, in der Nähe von Fucecchio, San Miniato und Vinci."
>
  <HreflangLinks slot="head" />

  <HeroLang
    badge="Webagentur in der Toskana"
    titleBefore="Webseiten, die aus Ideen "
    titleHighlight="echte Kunden machen"
    description="Wir gestalten schnelle, moderne und maßgeschneiderte Webseiten für Unternehmen und Selbstständige in der Toskana — dazu SEO- und Social-Media-Strategien, damit Sie online gefunden werden."
    extraParagraph="Wir sitzen zwischen Florenz und Pisa und betreuen Kunden in ganz Italien und im Ausland: Das gesamte Projekt läuft bequem online, vom ersten Gespräch bis zum Launch. Ohne Fachchinesisch, ohne versteckte Kosten — nur eine Webseite, die wirklich neue Kunden bringt."
    ctaPrimaryHref="mailto:info@manvitech.it"
    ctaPrimaryLabel="Kontakt aufnehmen"
    ctaSecondaryHref="/"
    ctaSecondaryLabel="Italienische Version"
    trustPoints={[
      { text: 'Schnelle, maßgeschneiderte Webseiten' },
      { text: 'SEO und Social Media inklusive' },
      { text: 'Die Webseite gehört zu 100% Ihnen' },
    ]}
  />
</Layout>
