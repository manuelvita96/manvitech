---
import Layout from '../layouts/Layout.astro';

// Segnaposto: sostituisci con i progetti reali (immagine, titolo, settore, link).
const projects = [
  { name: 'Progetto in arrivo', sector: 'Ristorazione', color: 'from-brand-200 to-accent-400/30' },
  { name: 'Progetto in arrivo', sector: 'Retail', color: 'from-ink-100 to-brand-200' },
  { name: 'Progetto in arrivo', sector: 'Servizi professionali', color: 'from-accent-400/20 to-brand-300' },
];
---

<Layout
  title="Portfolio"
  description="Alcuni dei progetti realizzati da Manvitech: siti internet su misura per attività e professionisti."
>
  <section class="container-page py-16 sm:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <span class="badge">Portfolio</span>
      <h1 class="mt-4 text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">I nostri progetti</h1>
      <p class="mt-4 text-ink-500">Una selezione dei lavori realizzati. Presto qui troverai i casi studio completi.</p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((p) => (
        <div class="overflow-hidden rounded-3xl border border-ink-100 bg-white" style="box-shadow: var(--shadow-card);">
          <div class={`aspect-[4/3] w-full bg-gradient-to-br ${p.color}`}></div>
          <div class="p-6">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{p.sector}</span>
            <h2 class="mt-1 font-display text-lg font-semibold text-ink-900">{p.name}</h2>
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>
