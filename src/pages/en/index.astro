---
import Layout from '../../layouts/Layout.astro';
import HreflangLinks from '../../components/HreflangLinks.astro';

// Landing page EN indipendente (non un sito tradotto integralmente):
// pensata per intercettare ricerche in inglese e presentare l'azienda,
// con link di contatto verso il sito principale in italiano.
---

<Layout
  lang="en"
  title="Manvitech — Websites, SEO & Social Marketing (Italy)"
  description="Manvitech designs fast, modern websites and SEO strategies for businesses in Italy. Get in touch to discuss your project."
>
  <HreflangLinks slot="head" />
  <section class="container-page py-20 sm:py-28">
    <div class="mx-auto max-w-2xl text-center">
      <span class="badge">Italian web agency</span>
      <h1 class="mt-6 text-4xl font-bold tracking-tight text-ink-900 sm:text-5xl">
        Websites that turn ideas into <span class="text-gradient">real businesses</span>
      </h1>
      <p class="mx-auto mt-6 max-w-xl text-lg text-ink-500">
        We design fast, modern, custom websites for businesses and professionals in Italy —
        along with SEO and social media strategy to help you get found online.
      </p>
      <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="mailto:info@manvitech.it" class="btn-primary w-full sm:w-auto">Get in touch</a>
        <a href="/" class="btn-ghost w-full sm:w-auto">Versione italiana</a>
      </div>
    </div>
  </section>
</Layout>
