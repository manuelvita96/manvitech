---
import Layout from '../../layouts/Layout.astro';
import HreflangLinks from '../../components/HreflangLinks.astro';
import HeroLang from '../../components/sections/HeroLang.astro';

// Landing page EN indipendente (non un sito tradotto integralmente):
// pensata per intercettare ricerche in inglese e presentare l'azienda,
// con link di contatto verso il sito principale in italiano.
---

<Layout
  lang="en"
  title="Manvitech — Websites, SEO & Social Marketing (Italy)"
  description="Manvitech designs fast, modern websites and SEO strategies for businesses in Italy. Get in touch to discuss your project."
>
  <HreflangLinks slot="head" />

  <HeroLang
    badge="Italian web agency"
    titleBefore="Websites that turn ideas into "
    titleHighlight="real businesses"
    description="We design fast, modern, custom websites for businesses and professionals in Italy — along with SEO and social media strategy to help you get found online."
    extraParagraph="Based near Florence and Pisa, we work with clients across Italy and abroad: the whole project — from first call to launch — runs smoothly online, wherever you are. No jargon, no bloated agency fees, just a site that actually brings in customers."
    ctaPrimaryHref="mailto:info@manvitech.it"
    ctaPrimaryLabel="Get in touch"
    ctaSecondaryHref="/"
    ctaSecondaryLabel="Versione italiana"
    trustPoints={[
      { text: 'Fast, modern, custom-built sites' },
      { text: 'SEO and social strategy included' },
      { text: 'You own 100% of your website' },
    ]}
  />
</Layout>
