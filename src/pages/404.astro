---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pagina non trovata" description="La pagina che cerchi non esiste." noindex={true}>
  <section class="container-page flex min-h-[60vh] flex-col items-center justify-center py-24 text-center">
    <span class="font-display text-gradient text-7xl font-bold">404</span>
    <h1 class="mt-4 text-2xl font-bold text-ink-900">Pagina non trovata</h1>
    <p class="mt-3 max-w-sm text-ink-500">La pagina che cerchi potrebbe essere stata spostata o non esiste più.</p>
    <a href="/" class="btn-primary mt-8">Torna alla home</a>
  </section>
</Layout>
