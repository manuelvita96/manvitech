---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const services = (await getCollection('pages')).sort((a, b) => a.data.order - b.data.order);
const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const zones = (await getCollection('local-seo', ({ data }) => !data.draft));
const cities = zones.filter((z) => z.data.pageType === 'city').sort((a, b) => (a.data.distanceKm ?? 999) - (b.data.distanceKm ?? 999));
const areas = zones.filter((z) => z.data.pageType === 'area');

const sections = [
  {
    title: 'Pagine principali',
    links: [
      { label: 'Home', href: '/' },
      { label: 'Chi siamo', href: '/chi-siamo' },
      { label: 'Contatti', href: '/contatti' },
      { label: 'Blog', href: '/blog' },
      { label: 'Dove operiamo', href: '/zone' },
    ],
  },
  {
    title: 'Servizi',
    links: services.map((s) => ({ label: s.data.title, href: `/servizi/${s.id}` })),
  },
  {
    title: 'Articoli del blog',
    links: posts.map((p) => ({ label: p.data.title, href: `/blog/${p.id}` })),
  },
  {
    title: 'Comuni',
    links: cities.map((z) => ({ label: z.data.city, href: `/zone/${z.id}` })),
  },
  {
    title: 'Zone',
    links: areas.map((z) => ({ label: z.data.city, href: `/zone/${z.id}` })),
  },
  {
    title: 'Legale',
    links: [
      { label: 'Privacy policy', href: '/privacy-policy' },
      { label: 'Cookie policy', href: '/cookie-policy' },
      { label: 'Termini e condizioni', href: '/termini-e-condizioni' },
      { label: 'Impressum', href: '/impressum' },
    ],
  },
];
---

<Layout
  title="Mappa del sito"
  description="Tutte le pagine del sito Manvitech in un unico elenco: servizi, blog, zone servite e informazioni legali."
>
  <Breadcrumbs items={[{ label: 'Mappa del sito', href: '/mappa-del-sito' }]} />
  <section class="container-page py-10 sm:py-16">
    <h1 class="text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">Mappa del sito</h1>
    <p class="mt-3 max-w-xl text-ink-500">Tutte le pagine di manvitech.it, per orientarti velocemente.</p>

    <div class="mt-12 grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
      {sections.map((section) => section.links.length > 0 && (
        <div>
          <h2 class="font-display text-base font-semibold text-ink-900">{section.title}</h2>
          <ul class="mt-3 space-y-2">
            {section.links.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-ink-500 hover:text-brand-600">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>
</Layout>
