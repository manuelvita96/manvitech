---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/sections/Hero.astro';
import Services from '../components/sections/Services.astro';
import SpeedCompare from '../components/sections/SpeedCompare.astro';
import BlogPreview from '../components/sections/BlogPreview.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': 'https://manvitech.it/#website',
  url: 'https://manvitech.it',
  name: 'Manvitech',
  description: 'Realizzazione siti internet, SEO e gestione social per attività e professionisti in Italia.',
  inLanguage: 'it-IT',
  publisher: { '@id': 'https://manvitech.it/#organization' },
};
---

<Layout
  title="Manvitech — Siti internet, SEO e social marketing"
  description="Realizziamo siti internet veloci, moderni e su misura. Design curato, SEO e gestione social per far crescere la tua attività online."
  jsonLd={jsonLd}
>
  <Hero />
  <Services />
  <SpeedCompare />
  <BlogPreview />

  <section class="container-page pb-24">
    <div
      class="relative overflow-hidden rounded-[2.5rem] px-8 py-16 text-center sm:px-16"
      style="background: linear-gradient(135deg, var(--color-ink-900), var(--color-ink-950));"
      data-reveal="scale"
    >
      <div
        aria-hidden="true"
        class="blob pointer-events-none absolute -right-20 -top-20 h-80 w-80 opacity-30 blur-3xl"
        style="background: linear-gradient(135deg, var(--color-brand-400), var(--color-accent-500));"
      ></div>
      <h2 class="relative font-display text-3xl font-bold text-white sm:text-4xl">
        Facciamo due chiacchiere?
      </h2>
      <p class="relative mx-auto mt-4 max-w-lg text-ink-300">
        Bastano due minuti per raccontarci cosa hai in mente. Ti rispondiamo entro 24 ore, senza impegno.
      </p>
      <a href="/contatti" class="btn-primary relative mt-8 inline-flex">Raccontaci il tuo progetto</a>
    </div>
  </section>
</Layout>
