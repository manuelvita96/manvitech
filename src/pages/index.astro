---
import Layout from '../layouts/Layout.astro';
import HreflangLinks from '../components/HreflangLinks.astro';
import Hero from '../components/sections/Hero.astro';
import DeviceShowcase from '../components/sections/DeviceShowcase.astro';
import Services from '../components/sections/Services.astro';
import ExistingSiteCta from '../components/sections/ExistingSiteCta.astro';
import SpeedCompare from '../components/sections/SpeedCompare.astro';
import WhyUs from '../components/sections/WhyUs.astro';
import Process from '../components/sections/Process.astro';
import Paths from '../components/sections/Paths.astro';
import BlogPreview from '../components/sections/BlogPreview.astro';
import Faq from '../components/Faq.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': 'https://manvitech.it/#website',
  url: 'https://manvitech.it',
  name: 'Manvitech',
  description: 'Realizzazione siti internet, SEO e gestione social per attività e professionisti in Italia.',
  inLanguage: 'it-IT',
  publisher: { '@id': 'https://manvitech.it/#organization' },
};

const homeFaq = [
  {
    question: 'Quanto costa un sito internet?',
    answer:
      'Dipende da cosa ti serve: un sito vetrina semplice ha un costo diverso da uno più articolato o da un e-commerce. Nella prima chiacchierata capiamo l\'obiettivo e ti diamo un preventivo chiaro, senza sorprese dopo.',
  },
  {
    question: 'Quanto tempo ci vuole per avere il sito online?',
    answer:
      'Per un sito vetrina, generalmente tra le 3 e le 5 settimane dal primo contatto, a seconda di quanto materiale (testi, foto) hai già pronto.',
  },
  {
    question: 'Il sito resta mio o resta vostro?',
    answer:
      'Il sito è tuo al 100%: dominio, codice e contenuti restano di tua proprietà. Se un giorno vuoi cambiare fornitore, puoi farlo senza vincoli.',
  },
  {
    question: 'Posso modificare i contenuti da solo dopo il lancio?',
    answer:
      'Sì, ti mostriamo come aggiornare testi, immagini e articoli del blog in autonomia. Se preferisci non pensarci, offriamo anche un servizio di manutenzione continua.',
  },
  {
    question: 'Lavorate solo con attività della zona di Fucecchio?',
    answer:
      'No, lavoriamo con clienti in tutta Italia. Conosciamo bene il territorio intorno a Fucecchio, ma gran parte del progetto si segue comodamente online ovunque tu sia.',
  },
];
---

<Layout
  title="Manvitech — Siti internet, SEO e social marketing"
  description="Realizziamo siti internet veloci, moderni e su misura. Design curato, SEO e gestione social per far crescere la tua attività online."
  jsonLd={jsonLd}
>
  <HreflangLinks slot="head" />
  <Hero />
  <DeviceShowcase />
  <Services />
  <ExistingSiteCta />
  <SpeedCompare />
  <WhyUs />
  <Process />
  <Paths />
  <BlogPreview />
  <Faq items={homeFaq} subtitle="Le domande che ci fanno più spesso, prima di iniziare a lavorare insieme." />

  <section class="container-page pb-24">
    <div
      class="relative overflow-hidden rounded-[2.5rem] px-8 py-16 text-center sm:px-16"
      style="background: linear-gradient(135deg, var(--color-ink-900), var(--color-ink-950));"
      data-reveal="scale"
    >
      <div
        aria-hidden="true"
        class="blob pointer-events-none absolute -right-20 -top-20 h-80 w-80 opacity-30 blur-3xl"
        style="background: linear-gradient(135deg, var(--color-brand-400), var(--color-accent-500));"
      ></div>
      <h2 class="relative font-display text-3xl font-bold text-white sm:text-4xl">
        Facciamo due chiacchiere?
      </h2>
      <p class="relative mx-auto mt-4 max-w-lg text-ink-300">
        Bastano due minuti per raccontarci cosa hai in mente. Ti rispondiamo entro 24 ore, senza impegno.
      </p>
      <a href="/contatti" class="btn-primary relative mt-8 inline-flex">Raccontaci il tuo progetto</a>
    </div>
  </section>
</Layout>
