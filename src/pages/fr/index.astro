---
import Layout from '../../layouts/Layout.astro';
import HreflangLinks from '../../components/HreflangLinks.astro';
---

<Layout
  lang="fr"
  title="Manvitech — Sites internet, SEO et réseaux sociaux (Toscane, Italie)"
  description="Manvitech conçoit des sites internet rapides et modernes, avec des stratégies SEO et social media efficaces, pour les entreprises de Toscane."
>
  <HreflangLinks slot="head" />

  <section class="container-page py-20 sm:py-28">
    <div class="mx-auto max-w-2xl text-center">
      <span class="badge">Agence web en Toscane</span>
      <h1 class="mt-6 text-4xl font-bold tracking-tight text-ink-900 sm:text-5xl">
        Des sites internet qui transforment vos idées <span class="text-gradient">en vrais clients</span>
      </h1>
      <p class="mx-auto mt-6 max-w-xl text-lg text-ink-500">
        Nous concevons des sites internet rapides, modernes et sur mesure pour les entreprises et
        indépendants de Toscane, avec des stratégies SEO et réseaux sociaux pour être trouvés en ligne.
      </p>
      <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="mailto:info@manvitech.it" class="btn-primary w-full sm:w-auto">Nous contacter</a>
        <a href="/" class="btn-ghost w-full sm:w-auto">Version italienne</a>
      </div>
    </div>
  </section>
</Layout>
