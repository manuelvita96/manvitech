---
import Layout from '../../layouts/Layout.astro';
import HreflangLinks from '../../components/HreflangLinks.astro';
import HeroLang from '../../components/sections/HeroLang.astro';
---

<Layout
  lang="fr"
  title="Manvitech — Sites internet, SEO et réseaux sociaux (Toscane, Italie)"
  description="Manvitech conçoit des sites internet rapides et modernes, avec des stratégies SEO et social media efficaces, pour les entreprises de Toscane."
>
  <HreflangLinks slot="head" />

  <HeroLang
    badge="Agence web en Toscane"
    titleBefore="Des sites internet qui transforment vos idées "
    titleHighlight="en vrais clients"
    description="Nous concevons des sites internet rapides, modernes et sur mesure pour les entreprises et indépendants de Toscane, avec des stratégies SEO et réseaux sociaux pour être trouvés en ligne."
    extraParagraph="Basés entre Florence et Pise, nous accompagnons des clients dans toute l'Italie et à l'étranger : tout le projet se déroule en ligne, du premier échange jusqu'à la mise en ligne. Sans jargon technique, sans mauvaises surprises — juste un site qui vous apporte de vrais clients."
    ctaPrimaryHref="mailto:info@manvitech.it"
    ctaPrimaryLabel="Nous contacter"
    ctaSecondaryHref="/"
    ctaSecondaryLabel="Version italienne"
    trustPoints={[
      { text: 'Sites rapides et sur mesure' },
      { text: 'SEO et réseaux sociaux inclus' },
      { text: 'Votre site vous appartient à 100%' },
    ]}
  />
</Layout>
