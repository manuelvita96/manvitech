---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const services = (await getCollection('pages')).sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title="Servizi"
  description="Siti internet, SEO, gestione social e graphic design: tutti i servizi di Manvitech per far crescere la tua attività online."
>
  <section class="container-page py-16 sm:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <span class="badge">I nostri servizi</span>
      <h1 class="mt-4 text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">Tutto quello che ti serve</h1>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2">
      {services.map((service) => (
        <a href={`/servizi/${service.id}`} class="rounded-3xl border border-ink-100 bg-white p-8 hover:border-brand-300" style="box-shadow: var(--shadow-card);">
          <h2 class="font-display text-xl font-semibold text-ink-900">{service.data.title}</h2>
          <p class="mt-2 text-ink-500">{service.data.description}</p>
          <span class="mt-4 inline-block text-sm font-semibold text-brand-600">Scopri di più →</span>
        </a>
      ))}
    </div>
  </section>
</Layout>
