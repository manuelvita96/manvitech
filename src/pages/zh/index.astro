---
import Layout from '../../layouts/Layout.astro';
import HreflangLinks from '../../components/HreflangLinks.astro';
---

<Layout
  lang="zh-Hans"
  title="Manvitech — 网站建设、SEO与社交媒体运营（意大利托斯卡纳）"
  description="Manvitech 为托斯卡纳地区的企业和个体经营者打造快速、现代化的定制网站，并提供SEO与社交媒体推广服务，帮助您在网上被更多人找到。"
>
  <HreflangLinks slot="head" />

  <section class="container-page py-20 sm:py-28">
    <div class="mx-auto max-w-2xl text-center">
      <span class="badge">托斯卡纳网络公司</span>
      <h1 class="mt-6 text-4xl font-bold tracking-tight text-ink-900 sm:text-5xl">
        让您的想法<span class="text-gradient">真正转化为客户</span>
      </h1>
      <p class="mx-auto mt-6 max-w-xl text-lg text-ink-500">
        我们为意大利托斯卡纳地区的企业和个体经营者打造快速、现代化且量身定制的网站，
        并提供SEO优化与社交媒体运营服务，让您的业务在网上被更多人看到。
      </p>
      <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="mailto:info@manvitech.it" class="btn-primary w-full sm:w-auto">联系我们</a>
        <a href="/" class="btn-ghost w-full sm:w-auto">意大利语版本</a>
      </div>
    </div>
  </section>
</Layout>
