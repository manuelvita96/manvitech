---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Cookie Policy" description="Informativa sull'utilizzo dei cookie sul sito Manvitech.">
  <article class="container-page py-16 sm:py-24">
    <div class="prose-article mx-auto max-w-2xl">
      <h1>Cookie Policy</h1>
      <p class="text-ink-400">
        <em>Contenuto segnaposto. Essendo il sito statico e senza tracker di default,
        qui va indicato solo l'eventuale uso futuro di cookie analitici/marketing.</em>
      </p>
    </div>
  </article>
</Layout>
