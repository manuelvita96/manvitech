---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Faq from '../../components/Faq.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const zones = await getCollection('local-seo', ({ data }) => !data.draft);
  return zones.map((zone) => ({
    params: { slug: zone.id },
    props: { zone, allZones: zones },
  }));
}

const { zone, allZones } = Astro.props;
const { Content } = await render(zone);

// Link agli altri comuni/zone pubblicati, per rafforzare il link interno locale
const otherZones = allZones
  .filter((z) => z.id !== zone.id)
  .sort((a, b) => (a.data.distanceKm ?? 999) - (b.data.distanceKm ?? 999))
  .slice(0, 6);

// LocalBusiness schema: rafforza la rilevanza locale per Google Maps,
// ricerca locale e per gli assistenti AI che rispondono a query geolocalizzate.
const jsonLd: Record<string, any> = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: `Manvitech — ${zone.data.city}`,
  description: zone.data.description,
  areaServed: zone.data.pageType === 'area'
    ? zone.data.nearbyTowns.map((t) => ({ '@type': 'City', name: t }))
    : { '@type': 'City', name: zone.data.city },
  parentOrganization: { '@id': 'https://manvitech.it/#organization' },
};

if (zone.data.latitude && zone.data.longitude) {
  jsonLd.geo = {
    '@type': 'GeoCoordinates',
    latitude: zone.data.latitude,
    longitude: zone.data.longitude,
  };
}
---

<Layout title={zone.data.title} description={zone.data.description} jsonLd={jsonLd}>
  <Breadcrumbs items={[{ label: 'Dove operiamo', href: '/zone' }, { label: zone.data.city, href: `/zone/${zone.id}` }]} />
  <article class="container-page py-10 sm:py-14">
    <div class="mx-auto max-w-2xl">
      <span class="badge">{zone.data.pageType === 'area' ? 'Macro-zona' : zone.data.city}</span>
      <h1 class="mt-4 text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">{zone.data.title}</h1>
      {zone.data.distanceKm != null && (
        <p class="mt-2 text-sm text-ink-400">A circa {zone.data.distanceKm} km da Fucecchio</p>
      )}
      <div class="prose-article mt-10">
        <Content />
      </div>

      {zone.data.nearbyTowns.length > 0 && (
        <div class="mt-10 rounded-2xl border border-ink-100 bg-ink-50/60 p-5">
          <p class="text-sm font-semibold text-ink-700">Zone coperte:</p>
          <p class="mt-1.5 text-sm text-ink-500">{zone.data.nearbyTowns.join(' · ')}</p>
        </div>
      )}

      <a href="/contatti" class="btn-primary mt-10 inline-flex">Richiedi informazioni</a>

      {otherZones.length > 0 && (
        <div class="mt-16 border-t border-ink-100 pt-10">
          <h2 class="font-display text-lg font-semibold text-ink-900">Operiamo anche in queste zone</h2>
          <div class="mt-5 flex flex-wrap gap-2.5">
            {otherZones.map((z) => (
              <a href={`/zone/${z.id}`} class="rounded-full border border-ink-100 px-4 py-2 text-sm font-medium text-ink-600 hover:border-brand-300 hover:text-brand-600">
                {z.data.city}
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </article>

  <Faq items={zone.data.faq} title={`Domande frequenti su ${zone.data.city}`} />
</Layout>
